<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:Shadow.ParadoxGameLauncher.Localization"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:models="using:Shadow.ParadoxGameLauncher.Models"
             xmlns:vm="using:Shadow.ParadoxGameLauncher.ViewModels"
             x:Class="Shadow.ParadoxGameLauncher.Views.ParadoxModsSectionView"
             x:Name="ModsSectionRoot"
             x:DataType="vm:ParadoxGameLauncherViewModel">
    <Grid
          RowDefinitions="Auto,*"
          RowSpacing="12">
        <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Paradox.Mods.Content.Header}"
                               Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Paradox.Mods.Content.Description}">
            <ui:FASettingsExpander.IconSource>
                <ui:FASymbolIconSource Symbol="Library"/>
            </ui:FASettingsExpander.IconSource>
            <ui:FASettingsExpander.Footer>
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button Click="ImportModButton_OnClick">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <ui:FASymbolIcon Symbol="OpenFile"/>
                            <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Paradox.Action.ImportMod}"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RefreshCommand}">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="6">
                            <ui:FASymbolIcon Symbol="Sync"/>
                            <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Paradox.Action.Refresh}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ui:FASettingsExpander.Footer>
        </ui:FASettingsExpander>
        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              RowSpacing="10">
            <TextBox PlaceholderText="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Paradox.Mods.Search.Placeholder}"
                     Text="{Binding ModSearchText}"
                     MinHeight="36"/>
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding FilteredMods}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="ClipToBounds" Value="True"/>
                        <Setter Property="Template">
                            <ControlTemplate>
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Padding="{TemplateBinding Padding}"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </ControlTemplate>
                        </Setter>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:ModEntry">
                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Margin="0">
                            <Grid ColumnDefinitions="92,*,Auto"
                                  MinHeight="70"
                                  ColumnSpacing="12">
                                <Border Width="92"
                                        Height="58"
                                        CornerRadius="6"
                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                        ClipToBounds="True"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <Image Source="{Binding CoverImage}"
                                               Stretch="UniformToFill"
                                               IsVisible="{Binding HasCoverImage}"/>
                                        <ui:FASymbolIcon Symbol="Image"
                                                         FontSize="24"
                                                         Opacity="0.54"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         IsVisible="{Binding IsCoverPlaceholderVisible}"/>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1"
                                            Spacing="4"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="6">
                                        <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                CornerRadius="4"
                                                Padding="5,1">
                                            <TextBlock Text="{Binding SourceLabel}"
                                                       FontSize="11"/>
                                        </Border>
                                        <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                CornerRadius="4"
                                                Padding="5,1">
                                            <TextBlock Text="{Binding VersionLabel}"
                                                       FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ContentPath}"
                                               FontSize="11"
                                               Opacity="0.62"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <Button Command="{Binding #ModsSectionRoot.((vm:ParadoxGameLauncherViewModel)DataContext).OpenModLocationCommand}"
                                            CommandParameter="{Binding}"
                                            Width="34"
                                            Height="34"
                                            Padding="0">
                                        <ui:FASymbolIcon Symbol="OpenFolder"/>
                                    </Button>
                                    <Button Command="{Binding #ModsSectionRoot.((vm:ParadoxGameLauncherViewModel)DataContext).OpenWorkshopPageCommand}"
                                            CommandParameter="{Binding}"
                                            Width="34"
                                            Height="34"
                                            Padding="0"
                                            IsVisible="{Binding CanOpenWorkshopPage}">
                                        <ui:FASymbolIcon Symbol="Globe"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
