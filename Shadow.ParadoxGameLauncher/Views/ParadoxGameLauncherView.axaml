<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:Shadow.ParadoxGameLauncher.Localization"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:models="using:Shadow.ParadoxGameLauncher.Models"
             xmlns:vm="using:Shadow.ParadoxGameLauncher.ViewModels"
             xmlns:views="using:Shadow.ParadoxGameLauncher.Views"
             x:Class="Shadow.ParadoxGameLauncher.Views.ParadoxGameLauncherView"
             x:Name="Root"
             x:DataType="vm:ParadoxGameLauncherViewModel">
    <Grid ColumnDefinitions="260,*"
          Margin="28,28,32,28">
        <Grid RowDefinitions="Auto,*"
              Margin="0,0,22,0">
            <StackPanel Spacing="6"
                        Margin="4,0,0,18">
                <Button Padding="0"
                        Margin="0"
                        MinHeight="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        ToolTip.Tip="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Paradox.GameSwitcher.Hint}">
                    <Button.Styles>
                        <Style Selector="Button">
                            <Setter Property="Background"
                                    Value="Transparent"/>
                            <Setter Property="BorderBrush"
                                    Value="Transparent"/>
                        </Style>
                        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background"
                                    Value="Transparent"/>
                        </Style>
                        <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background"
                                    Value="Transparent"/>
                        </Style>
                    </Button.Styles>
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedLeft"
                                OverlayDismissEventPassThrough="False">
                            <!-- Keep Fluent's default FlyoutPresenter template/animations, only strip the outer plate. -->
                            <Flyout.FlyoutPresenterTheme>
                                <ControlTheme TargetType="FlyoutPresenter"
                                              BasedOn="{StaticResource {x:Type FlyoutPresenter}}">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                    <Setter Property="BorderBrush"
                                            Value="Transparent"/>
                                    <Setter Property="BorderThickness"
                                            Value="0"/>
                                    <Setter Property="Padding"
                                            Value="0"/>
                                    <Setter Property="CornerRadius"
                                            Value="0"/>
                                </ControlTheme>
                            </Flyout.FlyoutPresenterTheme>
                            <Border Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                                    BorderBrush="{DynamicResource ComboBoxDropDownBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource OverlayCornerRadius}"
                                    Padding="4">
                                <ListBox ItemsSource="{Binding AvailableGames}"
                                         SelectedItem="{Binding SelectedGame}"
                                         MinWidth="240"
                                         MaxHeight="320"
                                         BorderThickness="0"
                                         Background="Transparent">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:ParadoxGameDefinition">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Margin="-4,6"
                                                       FontSize="16"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                    <TextBlock Text="{Binding SelectedGameDisplayName}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               TextDecorations="Underline"/>
                </Button>
                <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Paradox.Page.Subtitle}"
                           FontSize="13"
                           Opacity="0.68"/>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="11"
                           Opacity="0.56"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Sections}"
                     SelectedItem="{Binding SelectedSection}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:LauncherSection">
                        <Grid ColumnDefinitions="32,*"
                              Height="52">
                            <ui:FASymbolIcon Grid.Column="0"
                                             Symbol="{Binding Symbol}"
                                             FontSize="16"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1"
                                        Spacing="2"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="11"
                                           Opacity="0.62"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid Grid.Column="1"
              RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto"
                  Margin="0,2,0,10">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding SelectedSection.Title}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedSection.Description}"
                               FontSize="13"
                               Opacity="0.68"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding LaunchCommand}"
                        MinWidth="148"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Center">
                        <ui:FASymbolIcon Symbol="Play"/>
                        <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Paradox.Action.LaunchGame}"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid x:Name="LauncherContentHost"
                  Grid.Row="1">
                <views:ParadoxHomeSectionView IsVisible="{Binding IsHomeSelected}"/>
                <views:ParadoxModsSectionView IsVisible="{Binding IsModsSelected}"/>
                <views:ParadoxDlcsSectionView IsVisible="{Binding IsDlcsSelected}"/>
                <views:ParadoxPlaysetsSectionView IsVisible="{Binding IsPlaysetsSelected}"/>
                <views:ParadoxGameSettingsSectionView IsVisible="{Binding IsGameSettingsSelected}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
