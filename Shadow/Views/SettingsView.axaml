<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:Shadow.Abstractions"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:Shadow.ViewModels"
             x:Class="Shadow.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <Grid ColumnDefinitions="260,*"
          Margin="28,28,32,28">
        <Grid RowDefinitions="Auto,*"
              Margin="0,0,22,0">
            <StackPanel Spacing="6"
                        Margin="4,0,0,18">
                <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Page.Title}"
                           FontSize="28"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Page.Subtitle}"
                           FontSize="13"
                           Opacity="0.68"/>
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Sections}"
                     SelectedItem="{Binding SelectedSection}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SettingsSectionViewModel">
                        <Grid ColumnDefinitions="32,*"
                              Height="52">
                            <ui:FASymbolIcon Grid.Column="0"
                                             Symbol="{Binding Symbol}"
                                             FontSize="16"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1"
                                        Spacing="2"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="11"
                                           Opacity="0.62"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <ScrollViewer Grid.Column="1">
            <StackPanel x:Name="SettingsContentPanel"
                        Spacing="14"
                        MaxWidth="760">
                <StackPanel Spacing="4"
                            Margin="0,2,0,10">
                    <TextBlock Text="{Binding SelectedSection.Title}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedSection.Description}"
                               FontSize="13"
                               Opacity="0.68"/>
                </StackPanel>

                <StackPanel IsVisible="{Binding IsPersonalizationSelected}"
                            Spacing="12">
                    <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Language.Header}"
                                           Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Language.Description}">
                        <ui:FASettingsExpander.IconSource>
                            <ui:FASymbolIconSource Symbol="Globe"/>
                        </ui:FASettingsExpander.IconSource>
                        <ui:FASettingsExpander.Footer>
                            <ComboBox ItemsSource="{Binding LanguageOptions}"
                                      SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"
                                      Width="220"/>
                        </ui:FASettingsExpander.Footer>
                    </ui:FASettingsExpander>

                    <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Theme.Header}"
                                           Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Theme.Description}">
                        <ui:FASettingsExpander.IconSource>
                            <ui:FASymbolIconSource Symbol="Setting"/>
                        </ui:FASettingsExpander.IconSource>
                        <ui:FASettingsExpander.Footer>
                            <ComboBox SelectedIndex="{Binding SelectedThemeModeIndex, Mode=TwoWay}"
                                      Width="220">
                                <ComboBoxItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Theme.System}"/>
                                <ComboBoxItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Theme.Light}"/>
                                <ComboBoxItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Theme.Dark}"/>
                            </ComboBox>
                        </ui:FASettingsExpander.Footer>
                    </ui:FASettingsExpander>

                    <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Backdrop.Header}"
                                           Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Backdrop.Description}">
                        <ui:FASettingsExpander.IconSource>
                            <ui:FASymbolIconSource Symbol="Pictures"/>
                        </ui:FASettingsExpander.IconSource>
                        <ui:FASettingsExpander.Footer>
                            <ComboBox SelectedIndex="{Binding SelectedBackdropIndex, Mode=TwoWay}"
                                      Width="220">
                                <ComboBoxItem Content="Mica"/>
                                <ComboBoxItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Backdrop.Acrylic}"/>
                                <ComboBoxItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Backdrop.Solid}"/>
                            </ComboBox>
                        </ui:FASettingsExpander.Footer>
                    </ui:FASettingsExpander>

                    <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Accent.Header}"
                                           Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Accent.Description}">
                        <ui:FASettingsExpander.IconSource>
                            <ui:FASymbolIconSource Symbol="Edit"/>
                        </ui:FASettingsExpander.IconSource>
                        <ui:FASettingsExpander.Footer>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <Button Width="32"
                                        Height="32"
                                        Padding="0"
                                        Background="#5B7CFA"
                                        Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#5B7CFA"/>
                                <Button Width="32"
                                        Height="32"
                                        Padding="0"
                                        Background="#0078D4"
                                        Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#0078D4"/>
                                <Button Width="32"
                                        Height="32"
                                        Padding="0"
                                        Background="#0F7B6C"
                                        Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#0F7B6C"/>
                                <Button Width="32"
                                        Height="32"
                                        Padding="0"
                                        Background="#C239B3"
                                        Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#C239B3"/>
                                <Button Width="32"
                                        Height="32"
                                        Padding="0"
                                        Background="#D83B01"
                                        Command="{Binding SetAccentColorCommand}"
                                        CommandParameter="#D83B01"/>
                            </StackPanel>
                        </ui:FASettingsExpander.Footer>
                    </ui:FASettingsExpander>

                    <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.SystemAppearance.Header}"
                                           Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.SystemAppearance.Description}">
                        <ui:FASettingsExpander.IconSource>
                            <ui:FASymbolIconSource Symbol="Sync"/>
                        </ui:FASettingsExpander.IconSource>
                        <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.SystemAccent.Content}"
                                                   Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.SystemAccent.Description}">
                            <ui:FASettingsExpanderItem.Footer>
                                <ToggleSwitch IsChecked="{Binding Personalization.UseSystemAccentColor}"/>
                            </ui:FASettingsExpanderItem.Footer>
                        </ui:FASettingsExpanderItem>
                        <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.CompactSidebar.Content}"
                                                   Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.CompactSidebar.Description}">
                            <ui:FASettingsExpanderItem.Footer>
                                <ToggleSwitch IsChecked="{Binding Personalization.ShowCompactSidebar}"/>
                            </ui:FASettingsExpanderItem.Footer>
                        </ui:FASettingsExpanderItem>
                        <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Animations.Content}"
                                                   Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Animations.Description}">
                            <ui:FASettingsExpanderItem.Footer>
                                <ToggleSwitch IsChecked="{Binding Personalization.EnableAnimations}"/>
                            </ui:FASettingsExpanderItem.Footer>
                        </ui:FASettingsExpanderItem>
                    </ui:FASettingsExpander>
                </StackPanel>

                <StackPanel IsVisible="{Binding IsPluginInventorySelected}"
                            Spacing="12">
                    <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.Overview.Header}"
                                           Description="{Binding LoadedPluginCountLabel}">
                        <ui:FASettingsExpander.IconSource>
                            <ui:FASymbolIconSource Symbol="AllApps"/>
                        </ui:FASettingsExpander.IconSource>
                        <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.LoadingPolicy.Content}"
                                                   Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.LoadingPolicy.Description}"/>
                    </ui:FASettingsExpander>

                    <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.Empty.Header}"
                                           Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.Empty.Description}"
                                           IsVisible="{Binding IsNoPluginLoaded}">
                        <ui:FASettingsExpander.IconSource>
                            <ui:FASymbolIconSource Symbol="Help"/>
                        </ui:FASettingsExpander.IconSource>
                    </ui:FASettingsExpander>

                    <ItemsControl ItemsSource="{Binding LoadedPlugins}"
                                  IsVisible="{Binding HasLoadedPlugins}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="12"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PluginInfoViewModel">
                                <ui:FASettingsExpander Header="{Binding DisplayName}"
                                                       Description="{Binding Summary}">
                                    <ui:FASettingsExpander.IconSource>
                                        <ui:FASymbolIconSource Symbol="AllApps"/>
                                    </ui:FASettingsExpander.IconSource>
                                    <ui:FASettingsExpander.Footer>
                                        <TextBlock Text="{Binding VersionLabel}"
                                                   FontSize="12"
                                                   Opacity="0.72"/>
                                    </ui:FASettingsExpander.Footer>
                                    <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.Name}"
                                                               Description="{Binding DisplayName}"/>
                                    <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.Version}"
                                                               Description="{Binding VersionLabel}"/>
                                    <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.Id}"
                                                               Description="{Binding Id}"/>
                                    <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.Capabilities}"
                                                               Description="{Binding CapabilitySummary}"/>
                                    <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.Assembly}"
                                                               Description="{Binding AssemblyName}"/>
                                    <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.Type}">
                                        <ui:FASettingsExpanderItem.Footer>
                                            <TextBlock Text="{Binding PluginType}"
                                                       FontSize="12"
                                                       MaxWidth="460"
                                                       Opacity="0.72"
                                                       TextWrapping="Wrap"/>
                                        </ui:FASettingsExpanderItem.Footer>
                                    </ui:FASettingsExpanderItem>
                                    <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.DataDirectory}">
                                        <ui:FASettingsExpanderItem.Footer>
                                            <TextBlock Text="{Binding DataDirectory}"
                                                       FontSize="12"
                                                       MaxWidth="460"
                                                       Opacity="0.72"
                                                       TextWrapping="Wrap"/>
                                        </ui:FASettingsExpanderItem.Footer>
                                    </ui:FASettingsExpanderItem>
                                    <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Plugins.Location}">
                                        <ui:FASettingsExpanderItem.Footer>
                                            <TextBlock Text="{Binding Location}"
                                                       FontSize="12"
                                                       MaxWidth="460"
                                                       Opacity="0.72"
                                                       TextWrapping="Wrap"/>
                                        </ui:FASettingsExpanderItem.Footer>
                                    </ui:FASettingsExpanderItem>
                                </ui:FASettingsExpander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Placeholder.Header}"
                                        Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Shadow.Settings.Placeholder.Description}"
                                        IsVisible="{Binding IsPlaceholderSectionSelected}">
                    <ui:FASettingsExpander.IconSource>
                        <ui:FASymbolIconSource Symbol="Help"/>
                    </ui:FASettingsExpander.IconSource>
                </ui:FASettingsExpander>

                <ContentControl Content="{Binding SelectedSection.Content}"
                                IsVisible="{Binding IsPluginSectionSelected}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>



