<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:models="using:Shadow.Hoi4Launcher.Models"
             xmlns:vm="using:Shadow.Hoi4Launcher.ViewModels"
             x:Class="Shadow.Hoi4Launcher.Views.Hoi4LauncherView"
             x:Name="Root"
             x:DataType="vm:Hoi4LauncherViewModel">
    <Grid RowDefinitions="Auto,*"
          Margin="0">
        <Grid Height="74"
              ColumnDefinitions="*,Auto"
              Margin="28,18,28,0">
            <StackPanel Spacing="4"
                        VerticalAlignment="Center">
                <TextBlock Text="Hearts of Iron IV"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusText}"
                           FontSize="13"
                           Opacity="0.68"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
            <Button Grid.Column="1"
                    Command="{Binding LaunchCommand}"
                    MinWidth="148"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Center">
                    <ui:FASymbolIcon Symbol="Play" />
                    <TextBlock Text="开始游戏" />
                </StackPanel>
            </Button>
        </Grid>

        <ui:FANavigationView Grid.Row="1"
                             AlwaysShowHeader="False"
                             Background="Transparent"
                             IsBackButtonVisible="False"
                             IsPaneToggleButtonVisible="False"
                             IsSettingsVisible="False"
                             IsPaneOpen="True"
                             MenuItemsSource="{Binding Sections}"
                             OpenPaneLength="208"
                             PaneDisplayMode="Left"
                             SelectedItem="{Binding SelectedSection}">
            <ui:FANavigationView.MenuItemTemplate>
                <DataTemplate x:DataType="models:LauncherSection">
                    <ui:FANavigationViewItem Content="{Binding Title}"
                                             Tag="{Binding Key}"
                                             SelectsOnInvoked="True">
                        <ui:FANavigationViewItem.IconSource>
                            <ui:FASymbolIconSource Symbol="{Binding Symbol}" />
                        </ui:FANavigationViewItem.IconSource>
                    </ui:FANavigationViewItem>
                </DataTemplate>
            </ui:FANavigationView.MenuItemTemplate>

            <Grid Margin="0,0,28,26"
                  MaxWidth="980"
                  DataContext="{Binding #Root.DataContext}"
                  RowDefinitions="*">
                <ScrollViewer
                    IsVisible="{Binding #Root.DataContext.IsHomeSelected, FallbackValue=False, TargetNullValue=False}"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="18">
                        <Grid ColumnDefinitions="*,Auto"
                              Margin="0,2,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="启动首页"
                                           FontSize="24"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ActivePlaysetName}"
                                           FontSize="14"
                                           Opacity="0.68" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding RefreshCommand}"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Sync" />
                                    <TextBlock Text="刷新内容" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="12">
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding EnabledModCount}"
                                               FontSize="30"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="已启用 Mod"
                                               Opacity="0.68" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding PlaysetModCount}"
                                               FontSize="30"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="播放集内 Mod"
                                               Opacity="0.68" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding DisabledDlcCount}"
                                               FontSize="30"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="禁用 DLC"
                                               Opacity="0.68" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="150,*"
                                  RowSpacing="10"
                                  ColumnSpacing="14">
                                <TextBlock Text="游戏程序"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding GameExecutablePath}"
                                           TextTrimming="CharacterEllipsis"
                                           Opacity="0.82" />

                                <TextBlock Grid.Row="1"
                                           Text="用户目录"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Row="1"
                                           Grid.Column="1"
                                           Text="{Binding GameUserDirectory}"
                                           TextTrimming="CharacterEllipsis"
                                           Opacity="0.82" />

                                <TextBlock Grid.Row="2"
                                           Text="创意工坊"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="{Binding WorkshopDirectory}"
                                           TextTrimming="CharacterEllipsis"
                                           Opacity="0.82" />

                                <TextBlock Grid.Row="3"
                                           Text="启动参数"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Row="3"
                                           Grid.Column="1"
                                           Text="{Binding LaunchArguments}"
                                           TextTrimming="CharacterEllipsis"
                                           Opacity="0.82" />
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <Grid>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="当前播放集"
                                               FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding Playsets}"
                                              SelectedItem="{Binding SelectedPlayset}"
                                              Width="360"
                                              VerticalContentAlignment="Center"
                                              HorizontalAlignment="Left">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="models:Playset">
                                                <TextBlock Text="{Binding Name}"
                                                           VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid
                    IsVisible="{Binding #Root.DataContext.IsModsSelected, FallbackValue=False, TargetNullValue=False}"
                    RowDefinitions="Auto,*"
                    RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Mod 列表"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="所有已发现的本地和创意工坊 Mod"
                                       FontSize="14"
                                       Opacity="0.68" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding RefreshCommand}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <ui:FASymbolIcon Symbol="Sync" />
                                <TextBlock Text="刷新" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Mods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ModEntry">
                                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="92,*,Auto"
                                              MinHeight="70"
                                              ColumnSpacing="12">
                                            <Border Width="92"
                                                    Height="58"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                    ClipToBounds="True"
                                                    VerticalAlignment="Center">
                                                <Grid>
                                                    <Image Source="{Binding CoverImage}"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding HasCoverImage}" />
                                                    <ui:FASymbolIcon Symbol="Image"
                                                                     FontSize="24"
                                                                     Opacity="0.54"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     IsVisible="{Binding IsCoverPlaceholderVisible}" />
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6">
                                                    <Border
                                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                        CornerRadius="4"
                                                        Padding="5,1">
                                                        <TextBlock Text="{Binding SourceLabel}"
                                                                   FontSize="11" />
                                                    </Border>
                                                    <Border
                                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                        CornerRadius="4"
                                                        Padding="5,1">
                                                        <TextBlock Text="{Binding VersionLabel}"
                                                                   FontSize="11" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ContentPath}"
                                                           FontSize="11"
                                                           Opacity="0.62"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <Button Classes="Subtle"
                                                        Command="{Binding #Root.DataContext.OpenModLocationCommand}"
                                                        CommandParameter="{Binding}"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <ui:FASymbolIcon Symbol="OpenFolder" />
                                                </Button>
                                                <Button Classes="Subtle"
                                                        Command="{Binding #Root.DataContext.OpenWorkshopPageCommand}"
                                                        CommandParameter="{Binding}"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0"
                                                        IsVisible="{Binding CanOpenWorkshopPage}">
                                                    <ui:FASymbolIcon Symbol="Globe" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid
                    IsVisible="{Binding #Root.DataContext.IsDlcsSelected, FallbackValue=False, TargetNullValue=False}"
                    RowDefinitions="Auto,*"
                    RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock Text="DLC 列表"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="禁用的 DLC 会写入 dlc_load.json"
                                       FontSize="14"
                                       Opacity="0.68" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding EnableAllDlcsCommand}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <ui:FASymbolIcon Symbol="Accept" />
                                <TextBlock Text="启用全部" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Dlcs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DlcEntry">
                                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="14"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*"
                                              MinHeight="44"
                                              ColumnSpacing="12">
                                            <CheckBox IsChecked="{Binding IsEnabled}"
                                                      IsEnabled="{Binding #Root.DataContext.CanEditSelectedPlayset}"
                                                      VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        Spacing="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding Path}"
                                                           FontSize="11"
                                                           Opacity="0.62"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid
                    IsVisible="{Binding #Root.DataContext.IsPlaysetsSelected, FallbackValue=False, TargetNullValue=False}"
                    RowDefinitions="Auto,Auto,*"
                    RowSpacing="12">
                    <Grid ColumnDefinitions="Auto,280,Auto,Auto,*,Auto,Auto"
                          ColumnSpacing="8"
                          MinHeight="40">
                        <TextBlock Text="播放集"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Playsets}"
                                  SelectedItem="{Binding SelectedPlayset}"
                                  VerticalAlignment="Center"
                                  VerticalContentAlignment="Center"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Playset">
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="2"
                                Click="CreatePlaysetButton_OnClick">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <ui:FASymbolIcon Symbol="Add" />
                                <TextBlock Text="新增" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3"
                                IsEnabled="{Binding CanEditSelectedPlayset}"
                                Command="{Binding DeletePlaysetCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <ui:FASymbolIcon Symbol="Delete" />
                                <TextBlock Text="删除" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="5"
                                IsEnabled="{Binding CanEditSelectedPlayset}"
                                Click="AddModButton_OnClick">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <ui:FASymbolIcon Symbol="Add" />
                                <TextBlock Text="添加 Mod" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="6"
                                Margin="8,0,0,0"
                                Command="{Binding ImportParadoxPlaysetsCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="6">
                                <ui:FASymbolIcon Symbol="Download" />
                                <TextBlock Text="读取 P 社" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding ActivePlaysetName}"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="13"
                                       Opacity="0.68">
                                <Run Text="{Binding PlaysetModCount}" />
                                <Run Text=" 个 Mod，启用 " />
                                <Run Text="{Binding EnabledModCount}" />
                                <Run Text=" 个，" />
                                <Run Text="{Binding SelectedPlaysetEditStateText}" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="2"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="拖拽 Mod 卡片可调整加载顺序"
                                       Opacity="0.68"
                                       HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding SelectedPlaysetStorageDirectory}"
                                       FontSize="11"
                                       Opacity="0.52"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="PlaysetModsList"
                                      ItemsSource="{Binding PlaysetMods}"
                                      PointerMoved="PlaysetModsList_OnPointerMoved"
                                      PointerPressed="PlaysetModsList_OnPointerPressed"
                                      PointerReleased="PlaysetModsList_OnPointerReleased">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:PlaysetModEntry">
                                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,Auto,92,*,Auto"
                                              MinHeight="70"
                                              ColumnSpacing="12">
                                            <ui:FASymbolIcon Symbol="Sort"
                                                             Opacity="0.54"
                                                             VerticalAlignment="Center" />
                                            <CheckBox Grid.Column="1"
                                                      IsChecked="{Binding IsEnabled}"
                                                      IsEnabled="{Binding #Root.DataContext.CanEditSelectedPlayset}"
                                                      VerticalAlignment="Center" />

                                            <Border Grid.Column="2"
                                                    Width="92"
                                                    Height="58"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                    ClipToBounds="True"
                                                    VerticalAlignment="Center">
                                                <Grid>
                                                    <Image Source="{Binding CoverImage}"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding HasCoverImage}" />
                                                    <ui:FASymbolIcon Symbol="Image"
                                                                     FontSize="24"
                                                                     Opacity="0.54"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     IsVisible="{Binding IsCoverPlaceholderVisible}" />
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="3"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6">
                                                    <Border
                                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                        CornerRadius="4"
                                                        Padding="5,1">
                                                        <TextBlock Text="{Binding SourceLabel}"
                                                                   FontSize="11" />
                                                    </Border>
                                                    <Border
                                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                        CornerRadius="4"
                                                        Padding="5,1">
                                                        <TextBlock Text="{Binding VersionLabel}"
                                                                   FontSize="11" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Subtitle}"
                                                           FontSize="11"
                                                           Opacity="0.62"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="4"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <Button Classes="Subtle"
                                                        Command="{Binding #Root.DataContext.OpenModLocationCommand}"
                                                        CommandParameter="{Binding}"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <ui:FASymbolIcon Symbol="OpenFolder" />
                                                </Button>
                                                <Button Classes="Subtle"
                                                        Command="{Binding #Root.DataContext.OpenWorkshopPageCommand}"
                                                        CommandParameter="{Binding}"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0"
                                                        IsVisible="{Binding CanOpenWorkshopPage}">
                                                    <ui:FASymbolIcon Symbol="Globe" />
                                                </Button>
                                                <Button Classes="Subtle"
                                                        Command="{Binding #Root.DataContext.RemovePlaysetModCommand}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding #Root.DataContext.CanEditSelectedPlayset}"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <ui:FASymbolIcon Symbol="Delete" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <ScrollViewer DataContext="{Binding GameSettings}"
                              IsVisible="{Binding #Root.DataContext.IsGameSettingsSelected, FallbackValue=False, TargetNullValue=False}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="游戏设置"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="启动路径、启动行为以及 settings.txt 游戏选项"
                                       FontSize="14"
                                       Opacity="0.68" />
                        </StackPanel>

                        <ui:FASettingsExpander Header="启动路径"
                                               Description="游戏程序、HOI4 用户目录和 Steam 创意工坊目录。">
                            <ui:FASettingsExpander.IconSource>
                                <ui:FASymbolIconSource Symbol="Folder" />
                            </ui:FASettingsExpander.IconSource>
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="150,*"
                                  RowSpacing="10"
                                  ColumnSpacing="14"
                                  Margin="0,8,0,0">
                                <TextBlock Text="游戏程序"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding GameExecutablePath}"
                                         PlaceholderText="...\Hearts of Iron IV\hoi4.exe" />

                                <TextBlock Grid.Row="1"
                                           Text="用户目录"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Text="{Binding GameUserDirectory}"
                                         PlaceholderText="Documents\Paradox Interactive\Hearts of Iron IV" />

                                <TextBlock Grid.Row="2"
                                           Text="创意工坊目录"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Text="{Binding WorkshopDirectory}"
                                         PlaceholderText="...\steamapps\workshop\content\394360" />
                            </Grid>
                        </ui:FASettingsExpander>

                        <ui:FASettingsExpander Header="启动行为"
                                               Description="启动参数和启动后的应用行为。">
                            <ui:FASettingsExpander.IconSource>
                                <ui:FASymbolIconSource Symbol="Play" />
                            </ui:FASettingsExpander.IconSource>
                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="150,*"
                                  RowSpacing="10"
                                  ColumnSpacing="14"
                                  Margin="0,8,0,0">
                                <TextBlock Text="启动参数"
                                           VerticalAlignment="Center" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding LaunchArguments}"
                                         PlaceholderText="-debug -opengl" />

                                <TextBlock Grid.Row="1"
                                           Text="启动后"
                                           VerticalAlignment="Center" />
                                <ToggleSwitch Grid.Row="1"
                                              Grid.Column="1"
                                              Content="关闭 Shadow"
                                              IsChecked="{Binding CloseAfterLaunch}" />
                            </Grid>
                        </ui:FASettingsExpander>

                        <ui:FASettingsExpander Header="显示"
                                               Description="分辨率、显示模式、刷新率和垂直同步。">
                            <ui:FASettingsExpander.IconSource>
                                <ui:FASymbolIconSource Symbol="Pictures" />
                            </ui:FASettingsExpander.IconSource>
                            <Grid RowDefinitions="Auto,Auto,Auto"
                                  ColumnDefinitions="*,*"
                                  RowSpacing="10"
                                  ColumnSpacing="16"
                                  Margin="0,8,0,0">
                                <ComboBox ItemsSource="{Binding FullscreenModes}"
                                          SelectedIndex="{Binding SelectedFullscreenModeIndex}"
                                          HorizontalAlignment="Stretch" />
                                <ToggleSwitch Grid.Column="1"
                                              Content="垂直同步"
                                              IsChecked="{Binding VSync}" />
                                <StackPanel Grid.Row="1"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <NumericUpDown Value="{Binding ResolutionWidth}"
                                                   Minimum="640"
                                                   Maximum="7680"
                                                   Width="120" />
                                    <TextBlock Text="x"
                                               VerticalAlignment="Center" />
                                    <NumericUpDown Value="{Binding ResolutionHeight}"
                                                   Minimum="480"
                                                   Maximum="4320"
                                                   Width="120" />
                                </StackPanel>
                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <NumericUpDown Value="{Binding RefreshRate}"
                                                   Minimum="24"
                                                   Maximum="360"
                                                   Width="120" />
                                    <TextBlock Text="Hz"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <TextBlock Text="显示器"
                                               VerticalAlignment="Center" />
                                    <NumericUpDown Value="{Binding DisplayIndex}"
                                                   Minimum="0"
                                                   Maximum="8"
                                                   Width="120" />
                                </StackPanel>
                            </Grid>
                        </ui:FASettingsExpander>

                        <ui:FASettingsExpander Header="语言和音频"
                                               Description="对应原版启动器的语言与音量设置。">
                            <ui:FASettingsExpander.IconSource>
                                <ui:FASymbolIconSource Symbol="Audio" />
                            </ui:FASettingsExpander.IconSource>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="180,*"
                                  RowSpacing="10"
                                  ColumnSpacing="18"
                                  Margin="0,8,0,0">
                                <TextBlock Text="语言"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Languages}"
                                          SelectedItem="{Binding SelectedLanguage}"
                                          Width="220"
                                          HorizontalAlignment="Left" />

                                <TextBlock Grid.Row="1"
                                           Text="主音量"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Row="1"
                                        Grid.Column="1"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="{Binding MasterVolume}" />

                                <TextBlock Grid.Row="2"
                                           Text="音乐"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Row="2"
                                        Grid.Column="1"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="{Binding MusicVolume}" />

                                <TextBlock Grid.Row="3"
                                           Text="效果"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Row="3"
                                        Grid.Column="1"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="{Binding EffectsVolume}" />

                                <TextBlock Grid.Row="4"
                                           Text="界面"
                                           VerticalAlignment="Center" />
                                <Slider Grid.Row="4"
                                        Grid.Column="1"
                                        Minimum="0"
                                        Maximum="1"
                                        Value="{Binding InterfaceVolume}" />
                            </Grid>
                        </ui:FASettingsExpander>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="{Binding StatusText}"
                                       VerticalAlignment="Center"
                                       Opacity="0.68" />
                            <Button Command="{Binding ReloadCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Sync" />
                                    <TextBlock Text="重新读取" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SaveCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Save" />
                                    <TextBlock Text="保存" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </ui:FANavigationView>
    </Grid>
</UserControl>