<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:Shadow.Hoi4Launcher.Localization"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:models="using:Shadow.Hoi4Launcher.Models"
             xmlns:vm="using:Shadow.Hoi4Launcher.ViewModels"
             x:Class="Shadow.Hoi4Launcher.Views.Hoi4LauncherView"
             x:Name="Root"
             x:DataType="vm:Hoi4LauncherViewModel">
    <Grid ColumnDefinitions="260,*"
          Margin="28,28,32,28">
        <Grid RowDefinitions="Auto,*"
              Margin="0,0,22,0">
            <StackPanel Spacing="6"
                        Margin="4,0,0,18">
                <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Page.Title}"
                           FontSize="28"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Page.Subtitle}"
                           FontSize="13"
                           Opacity="0.68"/>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="11"
                           Opacity="0.56"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding Sections}"
                     SelectedItem="{Binding SelectedSection}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:LauncherSection">
                        <Grid ColumnDefinitions="32,*"
                              Height="52">
                            <ui:FASymbolIcon Grid.Column="0"
                                             Symbol="{Binding Symbol}"
                                             FontSize="16"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1"
                                        Spacing="2"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="11"
                                           Opacity="0.62"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid Grid.Column="1"
              RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto"
                  Margin="0,2,0,10">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding SelectedSection.Title}"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedSection.Description}"
                               FontSize="13"
                               Opacity="0.68"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding LaunchCommand}"
                        MinWidth="148"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                HorizontalAlignment="Center">
                        <ui:FASymbolIcon Symbol="Play"/>
                        <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Action.LaunchGame}"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Grid x:Name="LauncherContentHost"
                  Grid.Row="1">
                <ScrollViewer IsVisible="{Binding IsHomeSelected}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="14"
                                MaxWidth="760">
                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="12">
                            <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding EnabledModCount}"
                                               FontSize="30"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Stat.EnabledMods}"
                                               Opacity="0.68"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding PlaysetModCount}"
                                               FontSize="30"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Stat.PlaysetMods}"
                                               Opacity="0.68"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding DisabledDlcCount}"
                                               FontSize="30"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Stat.DisabledDlcs}"
                                               Opacity="0.68"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Home.CurrentPlayset.Header}"
                                               Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Home.CurrentPlayset.Description}">
                            <ui:FASettingsExpander.IconSource>
                                <ui:FASymbolIconSource Symbol="BulletList"/>
                            </ui:FASettingsExpander.IconSource>
                            <ui:FASettingsExpander.Footer>
                                <ComboBox ItemsSource="{Binding Playsets}"
                                          SelectedItem="{Binding SelectedPlayset}"
                                          Width="280"
                                          VerticalContentAlignment="Center">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:Playset">
                                            <TextBlock Text="{Binding Name}"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </ui:FASettingsExpander.Footer>
                        </ui:FASettingsExpander>

                        <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.LaunchPaths.Header}"
                                               Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.LaunchPaths.Description}">
                            <ui:FASettingsExpander.IconSource>
                                <ui:FASymbolIconSource Symbol="Folder"/>
                            </ui:FASettingsExpander.IconSource>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Field.GameExecutable}"
                                                       Description="{Binding GameExecutablePath}"/>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Field.UserDirectory}"
                                                       Description="{Binding GameUserDirectory}"/>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Field.Workshop}"
                                                       Description="{Binding WorkshopDirectory}"/>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Field.LaunchArguments}"
                                                       Description="{Binding LaunchArguments}"/>
                        </ui:FASettingsExpander>
                    </StackPanel>
                </ScrollViewer>

                <Grid IsVisible="{Binding IsModsSelected}"
                      RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Mods.Content.Header}"
                                           Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Mods.Content.Description}">
                        <ui:FASettingsExpander.IconSource>
                            <ui:FASymbolIconSource Symbol="Library"/>
                        </ui:FASettingsExpander.IconSource>
                        <ui:FASettingsExpander.Footer>
                            <Button Command="{Binding RefreshCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Sync"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Action.Refresh}"/>
                                </StackPanel>
                            </Button>
                        </ui:FASettingsExpander.Footer>
                    </ui:FASettingsExpander>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Mods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ModEntry">
                                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="92,*,Auto"
                                              MinHeight="70"
                                              ColumnSpacing="12">
                                            <Border Width="92"
                                                    Height="58"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                    ClipToBounds="True"
                                                    VerticalAlignment="Center">
                                                <Grid>
                                                    <Image Source="{Binding CoverImage}"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding HasCoverImage}"/>
                                                    <ui:FASymbolIcon Symbol="Image"
                                                                     FontSize="24"
                                                                     Opacity="0.54"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center"
                                                                     IsVisible="{Binding IsCoverPlaceholderVisible}"/>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="6">
                                                    <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                            CornerRadius="4"
                                                            Padding="5,1">
                                                        <TextBlock Text="{Binding SourceLabel}"
                                                                   FontSize="11"/>
                                                    </Border>
                                                    <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                            CornerRadius="4"
                                                            Padding="5,1">
                                                        <TextBlock Text="{Binding VersionLabel}"
                                                                   FontSize="11"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ContentPath}"
                                                           FontSize="11"
                                                           Opacity="0.62"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <Button Command="{Binding #Root.((vm:Hoi4LauncherViewModel)DataContext).OpenModLocationCommand}"
                                                        CommandParameter="{Binding}"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <ui:FASymbolIcon Symbol="OpenFolder"/>
                                                </Button>
                                                <Button Command="{Binding #Root.((vm:Hoi4LauncherViewModel)DataContext).OpenWorkshopPageCommand}"
                                                        CommandParameter="{Binding}"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0"
                                                        IsVisible="{Binding CanOpenWorkshopPage}">
                                                    <ui:FASymbolIcon Symbol="Globe"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid IsVisible="{Binding IsDlcsSelected}"
                      RowDefinitions="Auto,*"
                      RowSpacing="12">
                    <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Dlcs.Loading.Header}"
                                           Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Dlcs.Loading.Description}">
                        <ui:FASettingsExpander.IconSource>
                            <ui:FASymbolIconSource Symbol="Shop"/>
                        </ui:FASettingsExpander.IconSource>
                        <ui:FASettingsExpander.Footer>
                            <Button Command="{Binding EnableAllDlcsCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Accept"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Action.EnableAll}"/>
                                </StackPanel>
                            </Button>
                        </ui:FASettingsExpander.Footer>
                    </ui:FASettingsExpander>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Dlcs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DlcEntry">
                                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="14"
                                            Margin="0,0,0,8">
                                        <Grid ColumnDefinitions="Auto,*"
                                              MinHeight="44"
                                              ColumnSpacing="12">
                                            <CheckBox IsChecked="{Binding IsEnabled}"
                                                      VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1"
                                                        Spacing="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Path}"
                                                           FontSize="11"
                                                           Opacity="0.62"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid IsVisible="{Binding IsPlaysetsSelected}"
                      RowDefinitions="Auto,Auto,*"
                      RowSpacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="8"
                          MinHeight="40">
                        <ComboBox ItemsSource="{Binding Playsets}"
                                  SelectedItem="{Binding SelectedPlayset}"
                                  Width="260"
                                  VerticalAlignment="Center"
                                  VerticalContentAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:Playset">
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Click="CreatePlaysetButton_OnClick">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Add"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Action.Add}"/>
                                </StackPanel>
                            </Button>
                            <Button IsEnabled="{Binding CanEditSelectedPlayset}"
                                    Command="{Binding DeletePlaysetCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Delete"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Action.Delete}"/>
                                </StackPanel>
                            </Button>
                            <Button IsEnabled="{Binding CanEditSelectedPlayset}"
                                    Click="AddModButton_OnClick">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Add"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Action.AddMod}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding ImportParadoxPlaysetsCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Download"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Action.ImportParadox}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{Binding ActivePlaysetName}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding SelectedPlaysetSummaryText}"
                                       FontSize="13"
                                       Opacity="0.68"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Spacing="2"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Playsets.DragHint}"
                                       Opacity="0.68"
                                       HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding SelectedPlaysetStorageDirectory}"
                                       FontSize="11"
                                       Opacity="0.52"
                                       TextTrimming="CharacterEllipsis"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2"
                          x:Name="PlaysetDragSurface"
                          ClipToBounds="False">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="PlaysetModsList"
                                          ItemsSource="{Binding PlaysetMods}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:PlaysetModEntry">
                                        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="8"
                                                Margin="0,0,0,8"
                                                Tag="{Binding}"
                                                PointerMoved="PlaysetModCard_OnPointerMoved"
                                                PointerPressed="PlaysetModCard_OnPointerPressed"
                                                PointerReleased="PlaysetModCard_OnPointerReleased">
                                            <Grid ColumnDefinitions="Auto,Auto,92,*,Auto"
                                                  MinHeight="70"
                                                  ColumnSpacing="12">
                                                <ui:FASymbolIcon Symbol="Sort"
                                                                 Opacity="0.54"
                                                                 VerticalAlignment="Center"/>
                                                <CheckBox Grid.Column="1"
                                                          IsChecked="{Binding IsEnabled}"
                                                          IsEnabled="{Binding #Root.((vm:Hoi4LauncherViewModel)DataContext).CanEditSelectedPlayset}"
                                                          VerticalAlignment="Center"/>

                                                <Border Grid.Column="2"
                                                        Width="92"
                                                        Height="58"
                                                        CornerRadius="6"
                                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                        ClipToBounds="True"
                                                        VerticalAlignment="Center">
                                                    <Grid>
                                                        <Image Source="{Binding CoverImage}"
                                                               Stretch="UniformToFill"
                                                               IsVisible="{Binding HasCoverImage}"/>
                                                        <ui:FASymbolIcon Symbol="Image"
                                                                         FontSize="24"
                                                                         Opacity="0.54"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"
                                                                         IsVisible="{Binding IsCoverPlaceholderVisible}"/>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="3"
                                                            Spacing="4"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="6">
                                                        <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                                CornerRadius="4"
                                                                Padding="5,1">
                                                            <TextBlock Text="{Binding SourceLabel}"
                                                                       FontSize="11"/>
                                                        </Border>
                                                        <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                                CornerRadius="4"
                                                                Padding="5,1">
                                                            <TextBlock Text="{Binding VersionLabel}"
                                                                       FontSize="11"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               FontSize="11"
                                                               Opacity="0.62"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="4"
                                                            Orientation="Horizontal"
                                                            Spacing="8"
                                                            VerticalAlignment="Center">
                                                    <Button Command="{Binding #Root.((vm:Hoi4LauncherViewModel)DataContext).OpenModLocationCommand}"
                                                            CommandParameter="{Binding}"
                                                            Width="34"
                                                            Height="34"
                                                            Padding="0">
                                                        <ui:FASymbolIcon Symbol="OpenFolder"/>
                                                    </Button>
                                                    <Button Command="{Binding #Root.((vm:Hoi4LauncherViewModel)DataContext).OpenWorkshopPageCommand}"
                                                            CommandParameter="{Binding}"
                                                            Width="34"
                                                            Height="34"
                                                            Padding="0"
                                                            IsVisible="{Binding CanOpenWorkshopPage}">
                                                        <ui:FASymbolIcon Symbol="Globe"/>
                                                    </Button>
                                                    <Button Command="{Binding #Root.((vm:Hoi4LauncherViewModel)DataContext).RemovePlaysetModCommand}"
                                                            CommandParameter="{Binding}"
                                                            IsEnabled="{Binding #Root.((vm:Hoi4LauncherViewModel)DataContext).CanEditSelectedPlayset}"
                                                            Width="34"
                                                            Height="34"
                                                            Padding="0">
                                                        <ui:FASymbolIcon Symbol="Delete"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border x:Name="PlaysetInsertIndicator"
                                Height="3"
                                Margin="8,0"
                                CornerRadius="2"
                                Background="{DynamicResource SystemAccentColor}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                IsHitTestVisible="False"
                                IsVisible="False"
                                ZIndex="200"/>
                    </Grid>
                </Grid>

                <Grid IsVisible="{Binding IsGameSettingsSelected}">
                    <ScrollViewer DataContext="{Binding GameSettings}"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:DataType="vm:Hoi4GameSettingsViewModel"
                                    Spacing="12"
                                MaxWidth="760">
                        <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.LaunchPaths.Header}"
                                               Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.LaunchPaths.Description}">
                            <ui:FASettingsExpander.IconSource>
                                <ui:FASymbolIconSource Symbol="Folder"/>
                            </ui:FASettingsExpander.IconSource>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Field.GameExecutable}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.GameExecutable.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <TextBox Text="{Binding GameExecutablePath}"
                                             Width="430"
                                             PlaceholderText="...\Hearts of Iron IV\hoi4.exe"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Field.UserDirectory}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.UserDirectory.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <TextBox Text="{Binding GameUserDirectory}"
                                             Width="430"
                                             PlaceholderText="Documents\Paradox Interactive\Hearts of Iron IV"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Field.WorkshopDirectory}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.WorkshopDirectory.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <TextBox Text="{Binding WorkshopDirectory}"
                                             Width="430"
                                             PlaceholderText="...\steamapps\workshop\content\394360"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                        </ui:FASettingsExpander>

                        <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.LaunchBehavior.Header}"
                                               Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.LaunchBehavior.Description}">
                            <ui:FASettingsExpander.IconSource>
                                <ui:FASymbolIconSource Symbol="Play"/>
                            </ui:FASettingsExpander.IconSource>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Field.LaunchArguments}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.LaunchArguments.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <TextBox Text="{Binding LaunchArguments}"
                                             Width="300"
                                             PlaceholderText="-debug -opengl"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.CloseAfterLaunch.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.CloseAfterLaunch.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <ToggleSwitch IsChecked="{Binding CloseAfterLaunch}"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                        </ui:FASettingsExpander>

                        <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.Display.Header}"
                                               Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.Display.Description}">
                            <ui:FASettingsExpander.IconSource>
                                <ui:FASymbolIconSource Symbol="Pictures"/>
                            </ui:FASettingsExpander.IconSource>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.FullscreenMode.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.FullscreenMode.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <ComboBox ItemsSource="{Binding FullscreenModes}"
                                              SelectedIndex="{Binding SelectedFullscreenModeIndex}"
                                              Width="220"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.VSync.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.VSync.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <ToggleSwitch IsChecked="{Binding VSync}"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.Resolution.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.Resolution.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <NumericUpDown Value="{Binding ResolutionWidth}"
                                                       Minimum="640"
                                                       Maximum="7680"
                                                       Width="120"/>
                                        <TextBlock Text="x"
                                                   VerticalAlignment="Center"/>
                                        <NumericUpDown Value="{Binding ResolutionHeight}"
                                                       Minimum="480"
                                                       Maximum="4320"
                                                       Width="120"/>
                                    </StackPanel>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.RefreshRate.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.RefreshRate.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8">
                                        <NumericUpDown Value="{Binding RefreshRate}"
                                                       Minimum="24"
                                                       Maximum="360"
                                                       Width="120"/>
                                        <TextBlock Text="Hz"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.DisplayIndex.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.DisplayIndex.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <NumericUpDown Value="{Binding DisplayIndex}"
                                                   Minimum="0"
                                                   Maximum="8"
                                                   Width="120"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                        </ui:FASettingsExpander>

                        <ui:FASettingsExpander Header="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.LanguageAudio.Header}"
                                               Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.LanguageAudio.Description}">
                            <ui:FASettingsExpander.IconSource>
                                <ui:FASymbolIconSource Symbol="Audio"/>
                            </ui:FASettingsExpander.IconSource>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.Language.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.Language.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <ComboBox ItemsSource="{Binding Languages}"
                                              SelectedItem="{Binding SelectedLanguage}"
                                              Width="220"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.MasterVolume.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.MasterVolume.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <Slider Minimum="0"
                                            Maximum="1"
                                            Value="{Binding MasterVolume}"
                                            Width="260"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.MusicVolume.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.MusicVolume.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <Slider Minimum="0"
                                            Maximum="1"
                                            Value="{Binding MusicVolume}"
                                            Width="260"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.EffectsVolume.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.EffectsVolume.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <Slider Minimum="0"
                                            Maximum="1"
                                            Value="{Binding EffectsVolume}"
                                            Width="260"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                            <ui:FASettingsExpanderItem Content="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.InterfaceVolume.Content}"
                                                       Description="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.GameSettings.InterfaceVolume.Description}">
                                <ui:FASettingsExpanderItem.Footer>
                                    <Slider Minimum="0"
                                            Maximum="1"
                                            Value="{Binding InterfaceVolume}"
                                            Width="260"/>
                                </ui:FASettingsExpanderItem.Footer>
                            </ui:FASettingsExpanderItem>
                        </ui:FASettingsExpander>

                        <StackPanel Orientation="Horizontal"
                                    Spacing="10"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="{Binding StatusText}"
                                       VerticalAlignment="Center"
                                       Opacity="0.68"/>
                            <Button Command="{Binding ReloadCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Sync"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Action.Reload}"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SaveCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <ui:FASymbolIcon Symbol="Save"/>
                                    <TextBlock Text="{Binding Localizer.Version, Converter={x:Static loc:LocStringConverter.Instance}, ConverterParameter=Hoi4.Action.Save}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

